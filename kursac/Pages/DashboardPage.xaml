<UserControl x:Class="FamilyBudget.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FamilyBudget.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexBrush"/>
        <conv:TransactionTypeToColorConverter x:Key="TypeColor"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14,10,14,16">
            <Border CornerRadius="20" Margin="0,0,0,12" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#880E4F" Offset="0"/>
                        <GradientStop Color="#C2185B" Offset="0.4"/>
                        <GradientStop Color="#E91E8C" Offset="0.75"/>
                        <GradientStop Color="#FF4081" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#E91E8C" BlurRadius="28" ShadowDepth="0" Opacity="0.45"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="💰  Общий баланс семьи"
                               Foreground="#FFE0F0" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>

                    <TextBlock x:Name="TxtBalance" Grid.Row="2"
                               Text="0 ₽" Foreground="White"
                               FontSize="36" FontWeight="Bold" FontFamily="Segoe UI"/>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Доходы" Foreground="#FFE0F0" FontSize="10" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtIncome" Text="0 ₽" Foreground="#A5F3A5" FontSize="16"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Расходы" Foreground="#FFE0F0" FontSize="10" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtExpenses" Text="0 ₽" Foreground="#FFAAAA" FontSize="16"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource CardGradBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="12,12">
                    <StackPanel>
                        <TextBlock Text="👨‍👩‍👧‍👦" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtMembers" Text="0" Foreground="White"
                                   FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Членов" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="9" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{StaticResource CardGradBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="12,12">
                    <StackPanel>
                        <TextBlock Text="🎯" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtGoalsCount" Text="0" Foreground="White"
                                   FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Целей" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="9" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Background="{StaticResource CardGradBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="12,12">
                    <StackPanel>
                        <TextBlock Text="🐖" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtSaved" Text="0" Foreground="{StaticResource PrimaryLightBrush}"
                                   FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        <TextBlock Text="Накоплено" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="9" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="16" Padding="16,14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Члены семьи" Foreground="White" FontSize="13"
                               FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="MembersOverview">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Margin="0,0,0,8" Padding="12,10"
                                        Background="#250F35">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="38" Height="38" CornerRadius="19"
                                                Background="{Binding AvatarColor, Converter={StaticResource HexBrush}}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="White"
                                                       FontSize="15" FontWeight="Bold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding Role}" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                        <!-- Balance -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock x:Name="BalTxt"
                                                       Foreground="{StaticResource IncomeBrush}"
                                                       FontSize="12" FontWeight="Bold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="16" Padding="16,14" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Последние операции" Foreground="White"
                                   FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                    </Grid>
                    <ItemsControl x:Name="RecentTransactions">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Margin="0,0,0,6" Padding="10,9"
                                        Background="#1E0C2E">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34" Height="34" CornerRadius="10"
                                                Background="{Binding Type, Converter={StaticResource TypeColor}}"
                                                Opacity="0.2"/>
                                        <TextBlock Text="{Binding CategoryIcon}" FontSize="17"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Description}" Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding MemberName}" Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="10" FontFamily="Segoe UI"/>
                                                <TextBlock Text=" • " Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                                <TextBlock Text="{Binding FormattedDate}" Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="10" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding FormattedAmount}"
                                                   Foreground="{Binding Type, Converter={StaticResource TypeColor}}"
                                                   FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── GOALS SUMMARY ─────────────────────────────────────── -->
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="16" Padding="16,14" Margin="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="Цели накоплений" Foreground="White"
                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="GoalsSummary">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                                            <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding ProgressText}"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    </Grid>
                                    <Border Height="6" CornerRadius="3" Background="#2E1445">
                                        <Grid>
                                            <Border x:Name="ProgBar" Height="6" CornerRadius="3"
                                                    HorizontalAlignment="Left">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#E91E8C"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
