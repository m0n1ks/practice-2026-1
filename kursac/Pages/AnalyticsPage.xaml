<UserControl x:Class="FamilyBudget.Pages.AnalyticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="14,10,14,20">
            <TextBlock Text="Аналитика" Foreground="White"
                       FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtAnalSubtitle" Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,14"/>
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="18" Padding="18,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="📊  Доходы vs Расходы" Foreground="White"
                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,14"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Доходы" Foreground="{StaticResource IncomeBrush}"
                                   FontSize="11" FontFamily="Segoe UI"/>
                        <Border Grid.Column="1" Grid.Row="0" Height="20" CornerRadius="6" Background="#1B3A1B">
                            <Grid>
                                <Border x:Name="IncomeBar" Height="20" CornerRadius="6" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#388E3C" Offset="0"/>
                                            <GradientStop Color="#66BB6A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#66BB6A" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="TxtIncomeVal" Grid.Column="2" Grid.Row="0"
                                   Foreground="{StaticResource IncomeBrush}" FontSize="11"
                                   FontFamily="Segoe UI" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" Text="Расходы" Foreground="{StaticResource ExpenseBrush}"
                                   FontSize="11" FontFamily="Segoe UI"/>
                        <Border Grid.Column="1" Grid.Row="2" Height="20" CornerRadius="6" Background="#3A1515">
                            <Grid>
                                <Border x:Name="ExpenseBar" Height="20" CornerRadius="6" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#C62828" Offset="0"/>
                                            <GradientStop Color="#EF5350" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#EF5350" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="TxtExpenseVal" Grid.Column="2" Grid.Row="2"
                                   Foreground="{StaticResource ExpenseBrush}" FontSize="11"
                                   FontFamily="Segoe UI" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Border Background="#1A0D26" CornerRadius="10" Padding="12,8">
                        <Grid>
                            <TextBlock Text="Чистый баланс" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtNetBalance" FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="18" Padding="18,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🏷️  Расходы по категориям" Foreground="White"
                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,14"/>
                    <ItemsControl x:Name="CategoryBreakdown">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                                            <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Amount}" Foreground="{StaticResource ExpenseBrush}"
                                                   FontSize="12" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    </Grid>
                                    <Border Height="7" CornerRadius="4" Background="#2E1445">
                                        <Grid>
                                            <Border x:Name="CatBar" Height="7" CornerRadius="4"
                                                    HorizontalAlignment="Left">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#E91E8C" Offset="0"/>
                                                        <GradientStop Color="#FF4081" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="18" Padding="18,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="👥  Вклад членов семьи" Foreground="White"
                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,14"/>
                    <ItemsControl x:Name="MemberContrib">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A0D26" CornerRadius="12" Padding="12,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="AvatarBorder" Width="34" Height="34" CornerRadius="17" VerticalAlignment="Center"
                                                Background="{Binding AvatarColorBrush}">
                                            <TextBlock Text="{Binding Initials}" Foreground="White"
                                                       FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding IncomeText}" Foreground="{StaticResource IncomeBrush}"
                                                           FontSize="10" FontFamily="Segoe UI"/>
                                                <TextBlock Text="  /  " Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                                <TextBlock Text="{Binding ExpenseText}" Foreground="{StaticResource ExpenseBrush}"
                                                           FontSize="10" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock x:Name="BalTxt2" Text="{Binding BalanceText}" FontSize="13" FontWeight="Bold"
                                                       FontFamily="Segoe UI" HorizontalAlignment="Right"
                                                       Foreground="{Binding BalanceBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="18" Padding="18,16">
                <StackPanel>
                    <TextBlock Text="🎯  Прогресс целей" Foreground="White"
                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,14"/>
                    <ItemsControl x:Name="GoalsProgress">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A0D26" CornerRadius="12" Padding="12,10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" Foreground="White"
                                                           FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding CurrentAmount, StringFormat={}{0:N0} ₽}"
                                                           Foreground="{StaticResource PrimaryLightBrush}"
                                                           FontSize="12" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                <TextBlock Text=" / " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                                <TextBlock Text="{Binding TargetAmount, StringFormat={}{0:N0} ₽}"
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border Height="7" CornerRadius="4" Background="#2E1445">
                                            <Grid>
                                                <Border x:Name="GPBar" Height="7" CornerRadius="4" HorizontalAlignment="Left"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
