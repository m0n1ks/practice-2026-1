<UserControl x:Class="FamilyBudget.Pages.GoalsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FamilyBudget.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexBrush"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14,10,14,80">
                <Grid Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Цели накоплений" Foreground="White"
                                   FontSize="20" FontWeight="Bold" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtGoalsSub" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
                <Border CornerRadius="16" Margin="0,0,0,14" Padding="18,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4A148C" Offset="0"/>
                            <GradientStop Color="#7B1FA2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#7B1FA2" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="🐖  Всего накоплено" Foreground="#E1BEE7" FontSize="11" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtTotalSaved" Text="0 ₽" Foreground="White"
                                       FontSize="28" FontWeight="Bold" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock x:Name="TxtGoalsComplete" Foreground="#CE93D8" FontSize="12" FontFamily="Segoe UI" TextAlignment="Right"/>
                            <TextBlock x:Name="TxtGoalsActive" Foreground="#CE93D8" FontSize="11" FontFamily="Segoe UI" TextAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ItemsControl x:Name="GoalsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="20" Margin="0,0,0,12"
                                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1E0E2E" Offset="0"/>
                                        <GradientStop Color="#260F35" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="2" Opacity="0.35"/>
                                </Border.Effect>

                                <StackPanel>
                                    <!-- Coloured top strip -->
                                    <Border CornerRadius="20,20,0,0" Height="8"
                                            Background="{Binding Color, Converter={StaticResource HexBrush}}"/>

                                    <StackPanel Margin="16,12,16,16">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Icon}" FontSize="26" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="White"
                                                           FontSize="15" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource FlatBtn}"
                                                    Tag="{Binding Id}" Click="DeleteGoal_Click" VerticalAlignment="Top">
                                                <TextBlock Text="🗑" FontSize="14"/>
                                            </Button>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Накоплено" Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="10" FontFamily="Segoe UI"/>
                                                <TextBlock x:Name="CurAmtTxt" Foreground="White"
                                                           FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="Цель" Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="10" FontFamily="Segoe UI" TextAlignment="Right"/>
                                                <TextBlock x:Name="TgtAmtTxt" Foreground="{StaticResource TextSecBrush}"
                                                           FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Border Height="10" CornerRadius="5" Background="#2E1445"/>
                                            <Border x:Name="GoalProg" Height="10" CornerRadius="5" HorizontalAlignment="Left"
                                                    Background="{Binding Color, Converter={StaticResource HexBrush}}">
                                            </Border>
                                        </Grid>
                                        <Grid Margin="0,0,0,12">
                                            <TextBlock x:Name="ProgPctTxt" Foreground="{StaticResource PrimaryBrush}"
                                                       FontSize="12" FontWeight="Bold" FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding DeadlineText}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Style="{StaticResource PrimaryBtn}"
                                                    Tag="{Binding Id}" Click="AddMoney_Click"
                                                    Content="💰  Добавить деньги" FontSize="12" Padding="12,9"/>
                                            <Button Grid.Column="2" Style="{StaticResource OutlineBtn}"
                                                    Tag="{Binding Id}" Click="ViewTasks_Click"
                                                    Content="📋  Задачи" FontSize="12" Padding="12,9"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
        <Button Style="{StaticResource FABStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,18,18" Click="AddGoalBtn_Click" ToolTip="Новая цель">
            <TextBlock Text="+" Foreground="White" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI"
                       VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
        </Button>
        <Border x:Name="AddGoalOverlay" Visibility="Collapsed" Background="#CC000000">
            <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalAlignment="Center">
                <Border Background="{StaticResource CardGradBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="20" Padding="22,20" Margin="14,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#E91E8C" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="🎯  Новая цель" Foreground="White"
                                       FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                            <Button HorizontalAlignment="Right" Style="{StaticResource FlatBtn}"
                                    Click="CloseGoalOverlay_Click">
                                <TextBlock Text="✕" Foreground="{StaticResource TextMutedBrush}" FontSize="16"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="Название цели" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtGoalName" Style="{StaticResource ModernTB}" Margin="0,0,0,10"/>

                        <TextBlock Text="Описание" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtGoalDesc" Style="{StaticResource ModernTB}" Margin="0,0,0,10"/>

                        <TextBlock Text="Сумма цели (₽)" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtGoalTarget" Style="{StaticResource ModernTB}" Margin="0,0,0,10"/>

                        <TextBlock Text="Иконка" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <ComboBox x:Name="GoalIconSelect" Style="{StaticResource ModernCB}" Margin="0,0,0,10"/>

                        <TextBlock Text="Цвет" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <RadioButton x:Name="GC1" GroupName="GoalC" IsChecked="True" Margin="4,0">
                                <Border Width="28" Height="28" CornerRadius="14" Background="#E91E8C" Cursor="Hand"/>
                            </RadioButton>
                            <RadioButton x:Name="GC2" GroupName="GoalC" Margin="4,0">
                                <Border Width="28" Height="28" CornerRadius="14" Background="#7B1FA2" Cursor="Hand"/>
                            </RadioButton>
                            <RadioButton x:Name="GC3" GroupName="GoalC" Margin="4,0">
                                <Border Width="28" Height="28" CornerRadius="14" Background="#1565C0" Cursor="Hand"/>
                            </RadioButton>
                            <RadioButton x:Name="GC4" GroupName="GoalC" Margin="4,0">
                                <Border Width="28" Height="28" CornerRadius="14" Background="#FF6B35" Cursor="Hand"/>
                            </RadioButton>
                            <RadioButton x:Name="GC5" GroupName="GoalC" Margin="4,0">
                                <Border Width="28" Height="28" CornerRadius="14" Background="#00796B" Cursor="Hand"/>
                            </RadioButton>
                        </StackPanel>

                        <Button Style="{StaticResource PrimaryBtn}" Content="✅  Создать цель"
                                Click="ConfirmAddGoal_Click"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Border>
        <Border x:Name="AddMoneyOverlay" Visibility="Collapsed" Background="#CC000000">
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="20" Padding="22,20" Margin="18,0" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#7B1FA2" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <TextBlock x:Name="TxtAddMoneyTitle" Text="💰  Пополнить цель" Foreground="White"
                                   FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                        <Button HorizontalAlignment="Right" Style="{StaticResource FlatBtn}"
                                Click="CloseMoneyOverlay_Click">
                            <TextBlock Text="✕" Foreground="{StaticResource TextMutedBrush}" FontSize="16"/>
                        </Button>
                    </Grid>
                    <TextBlock Text="Сумма пополнения (₽)" Foreground="{StaticResource TextSecBrush}"
                               FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtAddAmount" Style="{StaticResource ModernTB}" Margin="0,0,0,16"/>
                    <Button Style="{StaticResource PrimaryBtn}" Content="💸  Пополнить"
                            Click="ConfirmAddMoney_Click"/>
                </StackPanel>
            </Border>
        </Border>
        <Border x:Name="TasksOverlay" Visibility="Collapsed" Background="#CC000000">
            <Border Background="{StaticResource CardGradBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="20" Padding="22,20" Margin="14,0"
                    MaxHeight="500" VerticalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <TextBlock x:Name="TxtTasksTitle" Text="📋  Задачи" Foreground="White"
                                   FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                        <Button HorizontalAlignment="Right" Style="{StaticResource FlatBtn}"
                                Click="CloseTasksOverlay_Click">
                            <TextBlock Text="✕" Foreground="{StaticResource TextMutedBrush}" FontSize="16"/>
                        </Button>
                    </Grid>
                    <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                        <ItemsControl x:Name="TasksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A0D26" CornerRadius="10" Padding="12,9" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsDone}" VerticalAlignment="Center"
                                                      Margin="0,0,10,0" Foreground="{StaticResource PrimaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center"
                                                       Foreground="White" FontSize="13" FontFamily="Segoe UI"/>
                                            <Button Grid.Column="2" Style="{StaticResource FlatBtn}"
                                                    Tag="{Binding Id}" Click="DeleteTask_Click">
                                                <TextBlock Text="✕" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtNewTask" Style="{StaticResource ModernTB}"/>
                        <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" Content="➕"
                                Click="AddTask_Click" Padding="14,10"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
