<UserControl x:Class="FamilyBudget.Pages.TransactionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FamilyBudget.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexBrush"/>
        <conv:TransactionTypeToColorConverter x:Key="TypeColor"/>
        <conv:TransactionTypeBgConverter x:Key="TypeBg"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14,10,14,80">
                <TextBlock Text="Операции" Foreground="White"
                           FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtTransSubtitle" Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,12"/>
                <Border Background="{StaticResource CardGradBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="4" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="FilterAll" Grid.Column="0" Style="{StaticResource PrimaryBtn}"
                                Content="Все" Click="FilterAll_Click" Padding="8,8" FontSize="12"/>
                        <Button x:Name="FilterIncome" Grid.Column="1" Style="{StaticResource FlatBtn}"
                                Click="FilterIncome_Click" Padding="8,8">
                            <TextBlock Text="Доходы" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="FilterExpense" Grid.Column="2" Style="{StaticResource FlatBtn}"
                                Click="FilterExpense_Click" Padding="8,8">
                            <TextBlock Text="Расходы" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                        </Button>
                    </Grid>
                </Border>
                <ComboBox x:Name="MemberFilter" Style="{StaticResource ModernCB}"
                          Margin="0,0,0,12" SelectionChanged="MemberFilter_Changed"/>
                <ItemsControl x:Name="TransList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Margin="0,0,0,8"
                                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1E0E2E" Offset="0"/>
                                        <GradientStop Color="#220F30" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Margin="14,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="{Binding Type, Converter={StaticResource TypeBg}}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CategoryIcon}" FontSize="17"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Description}" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                            <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,5,0"
                                                    Background="{Binding MemberColor, Converter={StaticResource HexBrush}}"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding MemberName}" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" FontFamily="Segoe UI"/>
                                            <TextBlock Text=" • " Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                            <TextBlock Text="{Binding Category}" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" FontFamily="Segoe UI"/>
                                            <TextBlock Text=" • " Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                            <TextBlock Text="{Binding FormattedDate}" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding FormattedAmount}"
                                               Foreground="{Binding Type, Converter={StaticResource TypeColor}}"
                                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="3" Style="{StaticResource FlatBtn}"
                                            Tag="{Binding Id}" Click="DeleteTransaction_Click"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="✕" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="TxtEmpty" Text="Нет операций" Foreground="{StaticResource TextMutedBrush}"
                           FontSize="14" FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Margin="0,30,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
        <Button Style="{StaticResource FABStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,18,18" Click="AddTransBtn_Click" ToolTip="Добавить операцию">
            <TextBlock Text="+" Foreground="White" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI"
                       VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
        </Button>
        <Border x:Name="AddTransOverlay" Visibility="Collapsed" Background="#CC000000">
            <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalAlignment="Center">
                <Border Background="{StaticResource CardGradBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="20" Padding="22,20" Margin="14,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#E91E8C" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="💸  Новая операция" Foreground="White"
                                       FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                            <Button HorizontalAlignment="Right" Style="{StaticResource FlatBtn}"
                                    Click="CloseTransOverlay_Click">
                                <TextBlock Text="✕" Foreground="{StaticResource TextMutedBrush}" FontSize="16"/>
                            </Button>
                        </Grid>
                        <Border Background="#1A0D26" CornerRadius="12" Padding="4" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="TypeIncomeBtn" Grid.Column="0" Style="{StaticResource GreenBtn}"
                                        Content="⬆ Доход" Click="SetTypeIncome_Click" FontSize="12"/>
                                <Button x:Name="TypeExpenseBtn" Grid.Column="1" Style="{StaticResource FlatBtn}"
                                        Click="SetTypeExpense_Click" Padding="8,8">
                                    <TextBlock Text="⬇ Расход" Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>
                        </Border>

                        <TextBlock Text="Сумма (₽)" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtAmount" Style="{StaticResource ModernTB}" Margin="0,0,0,10"/>

                        <TextBlock Text="Описание" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtDesc" Style="{StaticResource ModernTB}" Margin="0,0,0,10"/>

                        <TextBlock Text="Член семьи" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <ComboBox x:Name="MemberSelect" Style="{StaticResource ModernCB}" Margin="0,0,0,10"/>

                        <TextBlock Text="Категория" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CategorySelect" Style="{StaticResource ModernCB}" Margin="0,0,0,16"/>

                        <Button Style="{StaticResource PrimaryBtn}" Content="✅  Сохранить операцию"
                                Click="ConfirmAddTrans_Click"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
