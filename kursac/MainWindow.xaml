<Window x:Class="FamilyBudget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Семейный Бюджет"
        Width="430" Height="700"
        MinWidth="430" MinHeight="700"
        MaxWidth="430" MaxHeight="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="4,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="PreviewMouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="0.88" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="0.88" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource BgGradBrush}"
            CornerRadius="24"
            BorderBrush="#2E1445"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="10" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="Transparent"
                    MouseDown="TitleBar_MouseDown"
                    CornerRadius="24,24,0,0">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="10"
                                Background="{StaticResource PrimaryGradBrush}"
                                Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#E91E8C" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <TextBlock Text="💰" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="СЕМЕЙНЫЙ БЮДЖЕТ"
                                       Foreground="White" FontSize="13" FontWeight="Bold"
                                       FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtDate" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="10" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource FlatBtn}" Width="28" Height="28" Margin="0,0,4,0"
                                Click="MinimizeBtn_Click" ToolTip="Свернуть">
                            <Border Width="14" Height="2" Background="{StaticResource TextMutedBrush}" CornerRadius="1" VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource FlatBtn}" Width="28" Height="28"
                                Click="CloseBtn_Click" ToolTip="Закрыть">
                            <TextBlock Text="✕" Foreground="{StaticResource TextMutedBrush}" FontSize="13" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{StaticResource CardBorderBrush}"/>

            <ContentPresenter x:Name="PageContent" Grid.Row="1"/>
            <Border Grid.Row="2" Background="{StaticResource NavBgBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,24,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Dashboard -->
                    <Button x:Name="NavDashboard" Grid.Column="0" Style="{StaticResource NavBtn}"
                            Click="NavDashboard_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="BrdDash" Width="40" Height="40" CornerRadius="13"
                                    Background="#2A1040" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock Text="📊" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="LblDash" Text="Главная" FontSize="9" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Family -->
                    <Button x:Name="NavFamily" Grid.Column="1" Style="{StaticResource NavBtn}"
                            Click="NavFamily_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="BrdFam" Width="40" Height="40" CornerRadius="13"
                                    Background="#2A1040" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock Text="👨‍👩‍👧‍👦" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="LblFam" Text="Семья" FontSize="9" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Transactions -->
                    <Button x:Name="NavTrans" Grid.Column="2" Style="{StaticResource NavBtn}"
                            Click="NavTrans_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="BrdTrans" Width="40" Height="40" CornerRadius="13"
                                    Background="#2A1040" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock Text="💸" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="LblTrans" Text="Операции" FontSize="9" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Goals -->
                    <Button x:Name="NavGoals" Grid.Column="3" Style="{StaticResource NavBtn}"
                            Click="NavGoals_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="BrdGoals" Width="40" Height="40" CornerRadius="13"
                                    Background="#2A1040" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock Text="🎯" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="LblGoals" Text="Цели" FontSize="9" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Analytics -->
                    <Button x:Name="NavAnalytics" Grid.Column="4" Style="{StaticResource NavBtn}"
                            Click="NavAnalytics_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="BrdAnal" Width="40" Height="40" CornerRadius="13"
                                    Background="#2A1040" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock Text="📈" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="LblAnal" Text="Аналитика" FontSize="9" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
